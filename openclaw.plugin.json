{
  "id": "message-interceptor",
  "name": "Message Interceptor",
  "description": "Intercepts and transforms incoming messages before they reach the agent using OpenClaw SDK hooks",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable/disable interceptor globally"
      },
      "rules": {
        "type": "array",
        "description": "Message interception rules (can also be configured in code)",
        "items": {
          "type": "object",
          "required": ["pattern", "replacement"],
          "properties": {
            "pattern": {
              "type": "string",
              "description": "Text or regex pattern to match"
            },
            "replacement": {
              "type": "string",
              "description": "Replacement text"
            },
            "regex": {
              "type": "boolean",
              "default": false,
              "description": "Whether pattern is a regex"
            },
            "flags": {
              "type": "string",
              "description": "Regex flags (e.g., 'i' for case-insensitive)"
            }
          }
        }
      }
    },
    "additionalProperties": false
  }
}
